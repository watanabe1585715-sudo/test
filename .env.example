DATABASE_URL=postgres://recruit:recruit@localhost:5432/recruit?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-string
API_ADDR=:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# バッチの基準日を固定したい場合（省略時は Asia/Tokyo の当日）
# BATCH_DATE=2026-04-14

# メールワーカー（cmd/mailworker / docker compose mailworker）
# SMTP_HOST が空のときは送信せず終了（キューは pending のまま）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=noreply@example.com
# MAIL_BATCH_LIMIT=50
